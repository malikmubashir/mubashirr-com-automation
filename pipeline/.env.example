# Copy to .env and fill in. Never commit .env.

# WordPress
WP_BASE_URL=https://mubashirr.com
WP_USER=mubashir
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# Anthropic Claude (Writer)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# fal.ai (Visual)
FAL_KEY=fal-...

# Recipe data sources (Scout)
EDAMAM_APP_ID=...
EDAMAM_APP_KEY=...

# Stock photo fallback (Visual)
PEXELS_API_KEY=...

# Telegram approval gate (Publisher)
TELEGRAM_BOT_TOKEN=...
TELEGRAM_CHAT_ID=...
AUTO_PUBLISH_ON_TIMEOUT=true
TIMEOUT_MINUTES=120

# Social distribution
BUFFER_ACCESS_TOKEN=...

# Backup (Archivist)
B2_KEY_ID=...
B2_APP_KEY=...
B2_BUCKET=mubashirr-backups
AGE_RECIPIENT=age1...

# WP DB for archivist (use read-only credentials)
MYSQL_HOST=...
MYSQL_USER=...
MYSQL_PASSWORD=...
MYSQL_DB=mubashirr_wp
